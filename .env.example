# Database (PostgreSQL). Railway provides DATABASE_URL.
DATABASE_URL="postgresql://postgres:postgres@db:5432/myteam"

# Auth.js v5
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# Production URL (set in Railway). Required for Auth.js callbacks.
NEXTAUTH_URL="https://your-app.railway.app"

# Planning Center Online
# OAuth app (sign-in: identifies who the user is)
AUTH_PLANNING_CENTER_ID=""
AUTH_PLANNING_CENTER_SECRET=""
# Redirect URI: {NEXTAUTH_URL}/api/auth/callback/planning-center

# PCO API credentials (for background sync). HTTP Basic Auth. Separate from OAuth.
PCO_API_ID=""
PCO_API_SECRET=""
