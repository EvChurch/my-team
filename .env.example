# =============================================================================
# My Team - Environment Variables
# =============================================================================
# Both services (web + worker) need DATABASE_URL and PCO API credentials.
# The web service additionally needs auth credentials.
#
# On Railway, use variable references:
#   DATABASE_URL=${{Postgres.DATABASE_PRIVATE_URL}}
#   PCO_API_ID=${{shared.PCO_API_ID}}
#   PCO_API_SECRET=${{shared.PCO_API_SECRET}}
# =============================================================================

# --- Shared (both web + worker) ---

# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/myteam"

# Planning Center API credentials (for background sync)
PCO_API_ID=""
PCO_API_SECRET=""

# --- Web service only ---

# Auth.js secret (generate with: openssl rand -base64 32)
AUTH_SECRET=""

# Planning Center OAuth credentials (for user login)
AUTH_PLANNING_CENTER_ID=""
AUTH_PLANNING_CENTER_SECRET=""

# --- Railway-specific (set in dashboard, not in .env) ---

# HOSTNAME=0.0.0.0              # Required for standalone Next.js on Railway
# SKIP_ENV_VALIDATION=1         # Skip env validation during build phase
