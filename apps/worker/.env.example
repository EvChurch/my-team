# Database (PostgreSQL). Railway provides DATABASE_URL.
DATABASE_URL="postgresql://postgres:postgres@db:5432/myteam"

# PCO API credentials (for background sync). HTTP Basic Auth.
PCO_API_ID=""
PCO_API_SECRET=""

# Rock RMS API credentials (for background sync).
ROCK_BASE_URL=""
ROCK_API_KEY=""
ROCK_REST_KEY=""

# Optional comma-separated Rock group type IDs that should sync into My Team.
ROCK_TEAM_GROUP_TYPE_IDS=""
