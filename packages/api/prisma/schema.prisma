generator client {
  provider = "prisma-client"
  output   = "../generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

// --- Enums ---

enum Provider {
  PCO
  ROCK
}

enum ProfileMergeCandidateStatus {
  PENDING
  APPROVED
  DECLINED
}

enum GoalStatus {
  PENDING
  APPROVED
  DECLINED
  COMPLETED
}

enum FeedbackType {
  ENCOURAGEMENT
  GROWTH_AREA
  GENERAL
}

enum GuideCategory {
  QUICK_START
  TROUBLESHOOTING
  SOP
}

enum GuideStatus {
  DRAFT
  PUBLISHED
}

enum ThemePreference {
  LIGHT
  DARK
  SYSTEM
}

enum ScheduleStatus {
  CONFIRMED
  UNCONFIRMED
  DECLINED
}

// --- PCO-synced models (read-only from app perspective) ---

model Person {
  id        String   @id @default(cuid())
  remoteId  String
  provider  Provider
  email     String?
  fullName  String
  firstName String
  lastName  String
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leaders     Leader[]
  assignments Assignment[]

  schedules         Schedule[]

  profileIdentities ProfileIdentity[]

  @@unique([remoteId, provider])
}

model Profile {
  id          String   @id @default(cuid())
  displayName String
  fullName    String
  firstName   String
  lastName    String
  email       String?
  image       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  authAccounts     AuthAccount[]
  identities       ProfileIdentity[]
  mergeCandidates  ProfileMergeCandidate[] @relation("MergeCandidateProfile")
  duplicateMatches ProfileMergeCandidate[] @relation("MergeCandidateDuplicate")
  goalsOwned       Goal[]                  @relation("GoalOwner")
  goalsReviewed    Goal[]                  @relation("GoalReviewer")
  feedbackAuthored Feedback[]              @relation("FeedbackAuthor")
  feedbackReceived Feedback[]              @relation("FeedbackRecipient")
  guidesAuthored   Guide[]
  preferences      UserPreference?
}

model AuthAccount {
  id              String   @id @default(cuid())
  profileId       String
  provider        String
  providerAccountId String
  email           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([profileId])
}

model ProfileIdentity {
  id        String   @id @default(cuid())
  profileId String
  personId  String?
  provider  Provider
  remoteId  String
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  person  Person? @relation(fields: [personId], references: [id], onDelete: SetNull)

  @@unique([provider, remoteId])
  @@index([profileId])
  @@index([personId])
}

model ProfileMergeCandidate {
  id                 String                      @id @default(cuid())
  profileId          String
  duplicateProfileId String?
  provider           Provider?
  remoteId           String?
  confidence         Int
  reason             String
  status             ProfileMergeCandidateStatus @default(PENDING)
  sourceSnapshot     Json?
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt

  profile          Profile  @relation("MergeCandidateProfile", fields: [profileId], references: [id], onDelete: Cascade)
  duplicateProfile Profile? @relation("MergeCandidateDuplicate", fields: [duplicateProfileId], references: [id], onDelete: SetNull)

  @@index([profileId])
  @@index([duplicateProfileId])
  @@index([status])
}

model ServiceType {
  id        String   @id @default(cuid())
  remoteId  String
  provider  Provider
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teams Team[]

  @@unique([remoteId, provider])
}

model Team {
  id            String       @id @default(cuid())
  remoteId      String
  provider      Provider
  name          String
  description   Json?
  serviceTypeId String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  serviceType ServiceType? @relation(fields: [serviceTypeId], references: [id], onDelete: SetNull)
  leaders     Leader[]
  positions   Position[]
  goals       Goal[]
  feedback    Feedback[]
  guides      Guide[]
  schedules   Schedule[]

  @@unique([remoteId, provider])
}

model Position {
  id          String   @id @default(cuid())
  remoteId    String
  provider    Provider
  teamId      String
  name        String?
  description Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  team        Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  assignments Assignment[]
  guides      Guide[]      @relation("GuideRole")

  @@unique([remoteId, provider])
  @@index([teamId])
}

model Leader {
  id        String   @id @default(cuid())
  remoteId  String
  provider  Provider
  personId  String
  teamId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([personId, teamId])
  @@unique([remoteId, provider])
  @@index([teamId])
}

model Assignment {
  id         String   @id @default(cuid())
  remoteId   String
  provider   Provider
  personId   String
  positionId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  person   Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  position Position @relation(fields: [positionId], references: [id], onDelete: Cascade)

  @@unique([personId, positionId])
  @@unique([remoteId, provider])
  @@index([positionId])
}

model Schedule {
  id              String         @id @default(cuid())
  remoteId        String
  provider        Provider
  personId        String
  teamId          String
  positionName    String?
  serviceTypeName String
  status          ScheduleStatus
  sortDate        DateTime
  dates           String
  startsAt        DateTime?
  endsAt          DateTime?
  planRemoteId    String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  person    Person     @relation(fields: [personId], references: [id], onDelete: Cascade)
  team      Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  planTimes PlanTime[]

  @@unique([remoteId, provider])
  @@index([personId])
  @@index([teamId])
  @@index([personId, teamId])
  @@index([sortDate])
  @@index([planRemoteId, personId])
}

model PlanTime {
  id         String   @id @default(cuid())
  remoteId   String
  provider   Provider
  scheduleId String
  name       String?
  timeType   String?
  startsAt   DateTime?
  endsAt     DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  schedule Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@unique([remoteId, provider, scheduleId])
  @@index([scheduleId])
}

// --- App-native models (full CRUD) ---

model Goal {
  id          String     @id @default(cuid())
  title       String
  description String?
  progress    Int        @default(0)
  status      GoalStatus @default(PENDING)
  dueDate     DateTime?
  personId    String?
  teamId      String
  reviewedBy  String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  person   Profile? @relation("GoalOwner", fields: [personId], references: [id], onDelete: SetNull)
  team     Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  reviewer Profile? @relation("GoalReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@index([personId])
  @@index([teamId])
  @@index([teamId, status])
  @@index([reviewedBy])
}

model Feedback {
  id          String       @id @default(cuid())
  content     String
  type        FeedbackType
  authorId    String?
  recipientId String?
  teamId      String
  isShared    Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  author    Profile? @relation("FeedbackAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  recipient Profile? @relation("FeedbackRecipient", fields: [recipientId], references: [id], onDelete: SetNull)
  team      Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([recipientId])
  @@index([recipientId, teamId])
  @@index([authorId])
}

model Guide {
  id              String        @id @default(cuid())
  title           String
  content         Json
  category        GuideCategory
  status          GuideStatus   @default(DRAFT)
  authorId        String?
  teamId          String
  roleId          String?
  isPinned        Boolean       @default(false)
  isVisibleToTeam Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  author Profile?  @relation(fields: [authorId], references: [id], onDelete: SetNull)
  team   Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  role   Position? @relation("GuideRole", fields: [roleId], references: [id], onDelete: SetNull)

  @@index([teamId])
  @@index([teamId, status])
  @@index([teamId, roleId])
  @@index([roleId])
  @@index([authorId])
}

model UserPreference {
  id        String          @id @default(cuid())
  personId  String          @unique
  theme     ThemePreference @default(SYSTEM)
  locale    String          @default("en")
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  person Profile @relation(fields: [personId], references: [id], onDelete: Cascade)
}
