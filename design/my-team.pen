                              "fontWeight": "600"
                            },
                            {
                              "type": "text",
                              "id": "0QG4o",
                              "name": "p1",
                              "fill": "$--text-secondary",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "This guide covers the basics of operating the sound system at Grace Community Church. Whether you're new to the team or need a refresher, follow these steps to ensure a smooth service.",
                              "lineHeight": 1.6,
                              "fontFamily": "Outfit",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "QqA4Q",
                              "name": "h2",
                              "fill": "$--text-primary",
                              "content": "Before Service",
                              "fontFamily": "Outfit",
                              "fontSize": 18,
                              "fontWeight": "600"
                            },
                            {
                              "type": "text",
                              "id": "FX8A8",
                              "name": "p2",
                              "fill": "$--text-secondary",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "1. Arrive at least 45 minutes before service starts\n2. Power on the main console using the switch on the back panel\n3. Check that all channel faders are at unity (0 dB)\n4. Verify wireless microphone batteries are above 50%",
                              "lineHeight": 1.6,
                              "fontFamily": "Outfit",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "eTC3p",
                              "name": "h3",
                              "fill": "$--text-primary",
                              "content": "During Service",
                              "fontFamily": "Outfit",
                              "fontSize": 18,
                              "fontWeight": "600"
                            },
                            {
                              "type": "text",
                              "id": "WVluo",
                              "name": "p3",
                              "fill": "$--text-secondary",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "Monitor levels throughout the service. Keep the main output between -6 dB and 0 dB. Mute unused channels to reduce noise floor.",
                              "lineHeight": 1.6,
                              "fontFamily": "Outfit",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            }
