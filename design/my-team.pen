              "children": [
                {
                  "type": "frame",
                  "id": "FMcbH",
                  "name": "Welcome",
                  "width": "fill_container",
                  "fill": "$--bg-card",
                  "cornerRadius": 16,
                  "effect": {
                    "type": "shadow",
                    "shadowType": "outer",
                    "color": "#1A191808",
                    "offset": {
                      "x": 0,
                      "y": 2
                    },
