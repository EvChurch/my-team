                  },
                  "layout": "vertical",
                  "gap": 16,
                  "padding": 24,
                  "children": [
                    {
                      "type": "text",
                      "id": "yG8xb",
                      "name": "welcomeTitle",
                      "fill": "#1A1918",
                      "content": "Welcome",
                      "fontFamily": "Outfit",
                      "fontSize": 22,
                      "fontWeight": "600",
                      "letterSpacing": -0.3
                    },
                    {
                      "type": "text",
                      "id": "9sjYN",
                      "name": "welcomeBody",
                      "fill": "#6D6C6A",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Thank you for joining our volunteer team! We are so glad to have you on board. This guide will walk you through everything you need to know to get started, from what to expect on your first day to who you can reach out to with questions. Our community thrives because of generous people like you.",
                      "lineHeight": 1.5,
                      "fontFamily": "Outfit",
                      "fontSize": 15
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "aaCej",
                  "name": "What to Expect",
                  "width": "fill_container",
                  "fill": "$--bg-card",
                  "cornerRadius": 16,
                  "effect": {
                    "type": "shadow",
                    "shadowType": "outer",
                    "color": "#1A191808",
                    "offset": {
                      "x": 0,
                      "y": 2
                    },
                    "blur": 12
                  },
                  "layout": "vertical",
                  "gap": 16,
                  "padding": 24,
                  "children": [
                    {
                      "type": "text",
                      "id": "yujnJ",
                      "name": "expectTitle",
                      "fill": "#1A1918",
                      "content": "What to Expect",
                      "fontFamily": "Outfit",
                      "fontSize": 22,
                      "fontWeight": "600",
                      "letterSpacing": -0.3
                    },
                    {
                      "type": "text",
                      "id": "pDMY5",
                      "name": "expectBody",
                      "fill": "#6D6C6A",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "As a volunteer, you will be part of a welcoming and supportive team. Each Sunday, volunteers arrive 30 minutes before the service begins to set up and prepare. You will be paired with an experienced team member for your first few weeks to help you feel confident in your role. We value flexibility and understand that life happens — just let your team lead know if you need to swap a week.",
                      "lineHeight": 1.5,
                      "fontFamily": "Outfit",
                      "fontSize": 15
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "FjYD1",
                  "name": "Your First Sunday",
                  "width": "fill_container",
                  "fill": "$--bg-card",
                  "cornerRadius": 16,
                  "effect": {
                    "type": "shadow",
                    "shadowType": "outer",
                    "color": "#1A191808",
                    "offset": {
                      "x": 0,
                      "y": 2
                    },
                    "blur": 12
                  },
                  "layout": "vertical",
                  "gap": 16,
                  "padding": 24,
                  "children": [
                    {
                      "type": "text",
                      "id": "GZB1p",
                      "name": "sundayTitle",
                      "fill": "#1A1918",
                      "content": "Your First Sunday",
                      "fontFamily": "Outfit",
                      "fontSize": 22,
                      "fontWeight": "600",
                      "letterSpacing": -0.3
                    },
                    {
                      "type": "text",
                      "id": "DyTxx",
                      "name": "sundayBody",
                      "fill": "#6D6C6A",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Arrive at 8:30 AM and check in at the volunteer table near the main entrance. You will receive a name badge and a brief orientation from your team lead. During the service, shadow your assigned partner and observe how things flow. After the service, help with tear-down and join the team for a short debrief. Remember to wear comfortable shoes and bring a positive attitude!",
                      "lineHeight": 1.5,
                      "fontFamily": "Outfit",
                      "fontSize": 15
                    },
                    {
                      "type": "frame",
                      "id": "7U2J4",
